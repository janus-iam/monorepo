{
  "name": "janus",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.3.6",
      "typescript": "^5.9.3",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "better-auth": "^1.4.18",
      "@tailwindcss/vite": "^4.2.1",
      "@tanstack/react-router": "^1.132.0",
      "@tanstack/router-plugin": "^1.132.0",
      "@vitejs/plugin-react": "^6.0.1",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "lucide-react": "^0.575.0",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4.2.1",
      "tw-animate-css": "^1.4.0",
      "shadcn": "^4.0.8",
      "vite": "^8.0.0",
      "@types/node": "^22.19.15",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "next-themes": "^0.4.6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo -F web -F server dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:landing": "turbo -F landing dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @janus/db db:push",
    "db:studio": "turbo -F @janus/db db:studio",
    "db:generate": "turbo -F @janus/db db:generate",
    "db:migrate": "turbo -F @janus/db db:migrate",
    "db:start": "turbo -F @janus/db db:start",
    "db:watch": "turbo -F @janus/db db:watch",
    "db:stop": "turbo -F @janus/db db:stop",
    "db:down": "turbo -F @janus/db db:down",
    "check": "oxlint && oxfmt --write",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@janus/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@janus/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.13",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
